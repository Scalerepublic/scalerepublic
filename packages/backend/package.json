{
  "name": "backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./api": "./src/api/index.ts",
    "./api-client": "./src/api/client.ts",
    "./validation": "./src/lib/validation.ts"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "start:prod": "bun dist/index.js",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "cf:dev": "wrangler dev",
    "cf:cron": "wrangler dev --test-scheduled",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "lint": "eslint src tests",
    "test": "bun test",
    "check": "bunx tsc --noEmit",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:baseline": "bun scripts/baseline-migrations.ts",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio --host 0.0.0.0",
    "db:seed": "bun src/db/seed/index.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.4",
    "better-auth": "^1.6.9",
    "drizzle-orm": "^0.44.7",
    "hono": "^4.9.6",
    "postgres": "^3.4.7",
    "seedrandom": "^3.0.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260612.1",
    "@eslint/js": "^9.39.1",
    "@types/bun": "latest",
    "@types/node": "^25.7.0",
    "@types/seedrandom": "^3.0.8",
    "drizzle-kit": "^0.31.7",
    "eslint": "^9.39.1",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "jiti": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "wrangler": "^4.100.0"
  }
}
