compose_file := "./compose.yaml"
service := "backend"
db_url := "postgres://postgres:postgres@localhost:5432/scalerepublic"

default:
    @just --list

db-generate:
    bun run db:generate

db-baseline:
    DATABASE_URL={{db_url}} bun run db:baseline

db-migrate:
    docker compose -f {{compose_file}} exec {{service}} bun run db:migrate

db-reset:
    docker compose -f {{compose_file}} stop {{service}} 2>/dev/null || true
    just db-drop scalerepublic
    just db-drop scalerepublic_test
    docker compose -f {{compose_file}} start postgres {{service}} 2>/dev/null || docker compose -f {{compose_file}} up -d postgres {{service}}
    just db-migrate-all

db-clear:
    printf "SELECT 'TRUNCATE TABLE ' || string_agg(quote_ident(tablename), ', ') || ' RESTART IDENTITY CASCADE' FROM pg_tables WHERE schemaname = 'public'\n\\gexec\n" | docker compose -f {{compose_file}} exec -T postgres psql -U postgres -d scalerepublic

db-push:
    docker compose -f {{compose_file}} exec {{service}} bun run db:push

db-seed:
    docker compose -f {{compose_file}} exec {{service}} bun run db:seed

db-studio:
    docker compose -f {{compose_file}} exec {{service}} bun run db:studio

db-drop db_name:
    docker compose -f {{compose_file}} exec -T postgres psql -U postgres -d postgres -v ON_ERROR_STOP=1 -c "SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname = '{{db_name}}' AND pid <> pg_backend_pid();"
    docker compose -f {{compose_file}} exec postgres sh -c "dropdb -U postgres --if-exists {{db_name}} && createdb -U postgres {{db_name}}"

db-migrate-test:
    docker compose -f {{compose_file}} -f compose.test.yaml run --rm {{service}} bun run db:migrate

db-migrate-all:
    just db-migrate
    just db-migrate-test

test:
    #!/bin/sh
    docker compose -p scalerepublic-test -f compose.test.yaml up --build --exit-code-from backend --attach backend
    STATUS=$?
    docker compose -p scalerepublic-test -f compose.test.yaml down -v
    exit $STATUS

logs:
    docker compose -f {{compose_file}} logs -f {{service}}

shell:
    docker compose -f {{compose_file}} exec {{service}} sh

restart:
    docker compose -f {{compose_file}} restart {{service}}

rebuild:
    docker compose -f {{compose_file}} up {{service}} --build -d

up:
    docker compose -f {{compose_file}} up -d

down:
    docker compose -f {{compose_file}} down

dev:
    docker compose -f {{compose_file}} up -d && docker compose -f {{compose_file}} logs -f {{service}}

dev-local:
    bun run dev

lint:
    bun run lint
